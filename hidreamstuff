// Usage example
pub fn main() -> Result<()> {
    let config = PruningConfig {
        target_params: 8_000_000_000,
        original_params: 17_000_000_000,
        pruning_ratio: 0.47,
        preserve_critical_layers: true,
        moe_pruning_strategy: MoEPruningStrategy::Hybrid,
    };
    
    let pruner = HiDreamPruner::new(config);
    
    // Load original model
    let model = load_hidream_model("hidream-i1-dev")?;
    
    // Prune to 8B
    let pruned_model = pruner.prune_model(&model)?;
    
    // Save pruned model
    save_model(&pruned_model, "hidream-i1-8b")?;
    
    Ok(())
}
