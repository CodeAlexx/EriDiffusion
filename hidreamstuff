// hidream_component_analyzer.rs
// Tool to analyze which components to remove from HiDream dev model

use candle_core::{Device, DType, Tensor, Result};
use std::collections::{HashMap, BTreeMap};
use std::fs::File;
use std::io::Write;

/// Component importance analyzer for HiDream
pub struct HiDreamAnalyzer {
    device: Device,
    analysis_results: HashMap<String, ComponentAnalysis>,
}

#[derive(Debug, Clone)]
pub struct ComponentAnalysis {
    pub name: String,
    pub param_count: usize,
    pub activation_frequency: f32,
    pub gradient_magnitude: f32,
    pub output_contribution: f32,
    pub redundancy_score: f32,
    pub importance_score: f32,
}

impl HiDreamAnalyzer {
    pub fn new(device: Device) -> Self {
        Self {
            device,
            analysis_results: HashMap::new(),
        }
    }
    
    /// Step 1: Activation Frequency Analysis
    /// Track how often each component is activated during inference
    pub fn analyze_activation_patterns(
        &mut self,
        model: &HiDreamModel,
        test_dataset: &[TestSample],
    ) -> Result<HashMap<String, f32>> {
        println!("Analyzing activation patterns across {} samples...", test_dataset.len());
        
        let mut activation_counts: HashMap<String, usize> = HashMap::new();
        let mut total_activations: HashMap<String, f32> = HashMap::new();
        
        // Hook into model to track activations
        for sample in test_dataset {
            let activations = self.forward_with_hooks(model, sample)?;
            
            // Track MoE expert activations
            for (layer_idx, expert_activations) in activations.moe_experts.iter() {
                for (expert_idx, activation) in expert_activations.iter().enumerate() {
                    let key = format!("moe_layer_{}_expert_{}", layer_idx, expert_idx);
                    
                    // Count if expert was selected (activation > threshold)
                    if *activation > 0.1 {
                        *activation_counts.entry(key.clone()).or_insert(0) += 1;
                    }
                    
                    // Track total activation magnitude
                    *total_activations.entry(key).or_insert(0.0) += activation;
                }
            }
            
            // Track attention head activations
            for (layer_idx, head_activations) in activations.attention_heads.iter() {
                for (head_idx, activation) in head_activations.iter().enumerate() {
                    let key = format!("attn_layer_{}_head_{}", layer_idx, head_idx);
                    *total_activations.entry(key).or_insert(0.0) += activation;
                }
            }
        }
        
        // Normalize by number of samples
        let n_samples = test_dataset.len() as f32;
        let mut activation_frequencies = HashMap::new();
        
        for (key, count) in activation_counts {
            activation_frequencies.insert(key.clone(), count as f32 / n_samples);
        }
        
        Ok(activation_frequencies)
    }
    
    /// Step 2: Gradient-based Importance
    /// Measure how much each component affects the loss
    pub fn analyze_gradient_importance(
        &mut self,
        model: &HiDreamModel,
        validation_set: &[TestSample],
    ) -> Result<HashMap<String, f32>> {
        println!("Analyzing gradient importance...");
        
        let mut gradient_magnitudes: HashMap<String, f32> = HashMap::new();
        
        for sample in validation_set.iter().take(100) {  // Subset for efficiency
            // Forward pass
            let output = model.forward(&sample.input)?;
            let loss = self.compute_loss(&output, &sample.target)?;
            
            // Backward pass
            let gradients = loss.backward()?;
            
            // Analyze gradients for each component
            for (name, grad) in gradients {
                let magnitude = grad.abs()?.mean_all()?.to_scalar::<f32>()?;
                *gradient_magnitudes.entry(name).or_insert(0.0) += magnitude;
            }
        }
        
        // Normalize
        let n_samples = validation_set.len().min(100) as f32;
        for magnitude in gradient_magnitudes.values_mut() {
            *magnitude /= n_samples;
        }
        
        Ok(gradient_magnitudes)
    }
    
    /// Step 3: Output Contribution Analysis
    /// Measure how much each component contributes to final output
    pub fn analyze_output_contribution(
        &mut self,
        model: &HiDreamModel,
        test_samples: &[TestSample],
    ) -> Result<HashMap<String, f32>> {
        println!("Analyzing output contributions...");
        
        let mut contributions = HashMap::new();
        
        for sample in test_samples.iter().take(50) {
            // Get baseline output
            let baseline_output = model.forward(&sample.input)?;
            
            // Test each component by zeroing it out
            for component_name in self.get_component_names(model) {
                let modified_model = self.zero_out_component(model, &component_name)?;
                let modified_output = modified_model.forward(&sample.input)?;
                
                // Measure difference
                let diff = (&baseline_output - &modified_output)?
                    .abs()?
                    .mean_all()?
                    .to_scalar::<f32>()?;
                
                *contributions.entry(component_name).or_insert(0.0) += diff;
            }
        }
        
        // Normalize
        let n_samples = test_samples.len().min(50) as f32;
        for contrib in contributions.values_mut() {
            *contrib /= n_samples;
        }
        
        Ok(contributions)
    }
    
    /// Step 4: Redundancy Analysis
    /// Find components that are similar/redundant
    pub fn analyze_redundancy(
        &mut self,
        model: &HiDreamModel,
    ) -> Result<HashMap<String, f32>> {
        println!("Analyzing component redundancy...");
        
        let mut redundancy_scores = HashMap::new();
        
        // Analyze MoE expert similarity
        for layer_idx in 0..model.num_moe_layers() {
            let experts = model.get_moe_experts(layer_idx)?;
            
            for i in 0..experts.len() {
                let expert_i_weights = self.flatten_weights(&experts[i])?;
                let mut max_similarity = 0.0;
                
                for j in 0..experts.len() {
                    if i != j {
                        let expert_j_weights = self.flatten_weights(&experts[j])?;
                        let similarity = self.cosine_similarity(&expert_i_weights, &expert_j_weights)?;
                        max_similarity = max_similarity.max(similarity);
                    }
                }
                
                let key = format!("moe_layer_{}_expert_{}", layer_idx, i);
                redundancy_scores.insert(key, max_similarity);
            }
        }
        
        // Analyze attention head similarity
        for layer_idx in 0..model.num_attention_layers() {
            let heads = model.get_attention_heads(layer_idx)?;
            
            for i in 0..heads.len() {
                let head_i_weights = self.flatten_weights(&heads[i])?;
                let mut max_similarity = 0.0;
                
                for j in 0..heads.len() {
                    if i != j {
                        let head_j_weights = self.flatten_weights(&heads[j])?;
                        let similarity = self.cosine_similarity(&head_i_weights, &head_j_weights)?;
                        max_similarity = max_similarity.max(similarity);
                    }
                }
                
                let key = format!("attn_layer_{}_head_{}", layer_idx, i);
                redundancy_scores.insert(key, max_similarity);
            }
        }
        
        Ok(redundancy_scores)
    }
    
    /// Step 5: Text Encoder Analysis
    /// Analyze contribution of each text encoder
    pub fn analyze_text_encoders(
        &mut self,
        model: &HiDreamModel,
        test_prompts: &[String],
    ) -> Result<HashMap<String, f32>> {
        println!("Analyzing text encoder contributions...");
        
        let encoders = ["clip_l", "clip_g", "t5_xxl", "llama_3_1"];
        let mut encoder_importance = HashMap::new();
        
        for encoder_name in &encoders {
            let mut total_contribution = 0.0;
            
            for prompt in test_prompts {
                // Get baseline with all encoders
                let baseline = model.encode_text(prompt, None)?;
                
                // Get output without this encoder
                let without_encoder = model.encode_text(prompt, Some(encoder_name))?;
                
                // Measure difference
                let diff = (&baseline - &without_encoder)?
                    .abs()?
                    .mean_all()?
                    .to_scalar::<f32>()?;
                
                total_contribution += diff;
            }
            
            encoder_importance.insert(
                encoder_name.to_string(),
                total_contribution / test_prompts.len() as f32
            );
        }
        
        Ok(encoder_importance)
    }
    
    /// Combine all analyses to get final removal recommendations
    pub fn get_removal_recommendations(
        &mut self,
        model: &HiDreamModel,
        target_params: usize,
    ) -> Result<Vec<RemovalRecommendation>> {
        println!("\n=== Running comprehensive analysis ===");
        
        // Load test data
        let test_samples = self.load_test_samples(100)?;
        let test_prompts = self.load_test_prompts(50)?;
        
        // Run all analyses
        let activations = self.analyze_activation_patterns(model, &test_samples)?;
        let gradients = self.analyze_gradient_importance(model, &test_samples)?;
        let contributions = self.analyze_output_contribution(model, &test_samples)?;
        let redundancy = self.analyze_redundancy(model)?;
        let text_encoders = self.analyze_text_encoders(model, &test_prompts)?;
        
        // Combine scores
        let mut components = Vec::new();
        
        // Process each component
        for component_name in self.get_all_component_names(model) {
            let activation = activations.get(&component_name).unwrap_or(&0.0);
            let gradient = gradients.get(&component_name).unwrap_or(&0.0);
            let contribution = contributions.get(&component_name).unwrap_or(&0.0);
            let redundancy_score = redundancy.get(&component_name).unwrap_or(&0.0);
            
            // Calculate importance score (lower is less important)
            let importance = (activation * 0.2) + 
                           (gradient * 0.3) + 
                           (contribution * 0.3) + 
                           ((1.0 - redundancy_score) * 0.2);
            
            components.push(ComponentAnalysis {
                name: component_name.clone(),
                param_count: self.get_component_params(model, &component_name)?,
                activation_frequency: *activation,
                gradient_magnitude: *gradient,
                output_contribution: *contribution,
                redundancy_score: *redundancy_score,
                importance_score: importance,
            });
        }
        
        // Sort by importance (ascending - least important first)
        components.sort_by(|a, b| a.importance_score.partial_cmp(&b.importance_score).unwrap());
        
        // Generate removal recommendations
        let mut recommendations = Vec::new();
        let mut removed_params = 0;
        let current_params = model.total_parameters();
        let params_to_remove = current_params - target_params;
        
        // First, recommend removing LLaMA if it has low importance
        if let Some(llama_score) = text_encoders.get("llama_3_1") {
            if *llama_score < 0.3 {  // Threshold for removal
                recommendations.push(RemovalRecommendation {
                    component: "llama_3_1_encoder".to_string(),
                    params_saved: 8_000_000_000,
                    importance_loss: *llama_score,
                    reason: "Low contribution relative to parameter count".to_string(),
                });
                removed_params += 8_000_000_000;
            }
        }
        
        // Then recommend other components
        for component in components {
            if removed_params >= params_to_remove {
                break;
            }
            
            if component.importance_score < 0.3 {  // Threshold
                recommendations.push(RemovalRecommendation {
                    component: component.name.clone(),
                    params_saved: component.param_count,
                    importance_loss: component.importance_score,
                    reason: self.get_removal_reason(&component),
                });
                removed_params += component.param_count;
            }
        }
        
        // Save detailed report
        self.save_analysis_report(&components, &recommendations)?;
        
        Ok(recommendations)
    }
    
    /// Generate removal reason based on analysis
    fn get_removal_reason(&self, component: &ComponentAnalysis) -> String {
        if component.activation_frequency < 0.1 {
            "Rarely activated during inference".to_string()
        } else if component.redundancy_score > 0.9 {
            "High redundancy with other components".to_string()
        } else if component.output_contribution < 0.05 {
            "Minimal contribution to output quality".to_string()
        } else {
            "Low overall importance score".to_string()
        }
    }
    
    /// Save detailed analysis report
    fn save_analysis_report(
        &self,
        components: &[ComponentAnalysis],
        recommendations: &[RemovalRecommendation],
    ) -> Result<()> {
        let mut file = File::create("hidream_pruning_analysis.txt")?;
        
        writeln!(file, "=== HiDream Model Pruning Analysis Report ===")?;
        writeln!(file, "\nTop 10 Least Important Components:")?;
        
        for (i, component) in components.iter().take(10).enumerate() {
            writeln!(file, "\n{}. {}", i + 1, component.name)?;
            writeln!(file, "   Parameters: {:.2}M", component.param_count as f32 / 1_000_000.0)?;
            writeln!(file, "   Activation frequency: {:.2}%", component.activation_frequency * 100.0)?;
            writeln!(file, "   Gradient magnitude: {:.4}", component.gradient_magnitude)?;
            writeln!(file, "   Output contribution: {:.4}", component.output_contribution)?;
            writeln!(file, "   Redundancy score: {:.2}%", component.redundancy_score * 100.0)?;
            writeln!(file, "   Overall importance: {:.4}", component.importance_score)?;
        }
        
        writeln!(file, "\n\n=== Removal Recommendations ===")?;
        let total_params_removed: usize = recommendations.iter().map(|r| r.params_saved).sum();
        writeln!(file, "Total parameters to remove: {:.2}B", total_params_removed as f32 / 1_000_000_000.0)?;
        
        for rec in recommendations {
            writeln!(file, "\n- Remove: {}", rec.component)?;
            writeln!(file, "  Saves: {:.2}B parameters", rec.params_saved as f32 / 1_000_000_000.0)?;
            writeln!(file, "  Importance loss: {:.4}", rec.importance_loss)?;
            writeln!(file, "  Reason: {}", rec.reason)?;
        }
        
        Ok(())
    }
}

