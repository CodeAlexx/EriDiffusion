#!/bin/bash

# Pre-commit hook to detect fake code patterns

echo "🔍 Scanning for fake code patterns..."

FAKE_PATTERNS=(
  "TODO"
  "FIXME" 
  "XXX"
  "HACK"
  "BUG"
  "placeholder"
  "dummy"
  "mock"
  "fake"
  "not implemented"
  "unimplemented!"
  "todo!"
  "unreachable!()"
  "panic!(\"not implemented"
)

# Get list of staged Rust files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "\.rs$")

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FOUND_ISSUES=0
ISSUES=""

for file in $STAGED_FILES; do
  for pattern in "${FAKE_PATTERNS[@]}"; do
    MATCHES=$(grep -n "$pattern" "$file" 2>/dev/null | grep -v "test" | grep -v "#\[cfg(test)\]" || true)
    if [ ! -z "$MATCHES" ]; then
      ISSUES="$ISSUES\n\n$file:\n$MATCHES"
      FOUND_ISSUES=$((FOUND_ISSUES + $(echo "$MATCHES" | wc -l)))
    fi
  done
done

if [ $FOUND_ISSUES -gt 0 ]; then
  echo "❌ FAKE CODE DETECTED! Found $FOUND_ISSUES issues:"
  echo -e "$ISSUES"
  echo ""
  echo "Please fix these issues before committing."
  echo "To bypass this check (NOT RECOMMENDED), use: git commit --no-verify"
  exit 1
else
  echo "✅ No fake code patterns detected!"
fi